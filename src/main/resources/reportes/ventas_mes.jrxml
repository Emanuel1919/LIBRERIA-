<jasperReport name="ventas_mes" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="34942c16-b541-4d06-8be7-73174c39b64d">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL_Librovibe"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.report.description" value=""/>
	<query language="sql"><![CDATA[SELECT 
    v.id_venta,
    v.fecha_venta,
    u.username,
    v.total_venta
FROM ventas v
LEFT JOIN usuarios u 
    ON v.id_usuario = u.id_usuario
WHERE v.fecha_venta >= DATE_FORMAT(CURDATE(), '%Y-%m-01')
ORDER BY v.fecha_venta DESC]]></query>
